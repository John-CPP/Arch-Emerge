# arch-emerge example config. Copy to ~/.config/arch-emerge/emerge.toml,
# /etc/arch-emerge/emerge.toml, or ./emerge.toml and set [paths] for your system.
# Demo paths use /tmp/arch-emerge-demo/...

manual_update_packages = [
]
skip_install_packages = [
]

[paths]
packages_path = "/tmp/arch-emerge-demo/sources"
chroot_base_path = "/tmp/arch-emerge-demo/chroot"
ready_made_packages_path = "/tmp/arch-emerge-demo/emerge_ready"

[build]
default_environment = "local"
ignore_compilation_failures = false
compile_first_install_after = false
clean_install_by_default = false

[system_update]
command_to_update_repositories = "pacman -Su"
command_to_perform_system_update = "pacman -Syu"
ignore_flag = "--ignore"
ignore_packages = []

[repositories]
arch = "https://gitlab.archlinux.org/archlinux/packaging/packages"
cachyos = "https://github.com/CachyOS/CachyOS-PKGBUILDS.git"
default = "arch"

[packages]

# Example: Firefox-like PKGBUILDs need a clean `mozbuild/` before each build.
# [packages.firefox-pure]
# source = "ventureoo"
# build_env = "local"
# tests = true
# pre_update_command = "rm -rf mozbuild"
