# packages.config
# Package-specific configuration lives here.
#
# Compact package format:
#   PACKAGES["name"]="source=<repo> build_env=<local|chroot> tests=<on|off> alias=<base-pkg>"
#
# Supported keys:
# - source: repository key from REPOSITORIES
# - build_env: local or chroot
# - tests: on/off (off makes --nocheck default for this package)
# - alias: PKGBUILD base directory/package name

declare -A PACKAGES

# Examples
PACKAGES["systemd"]="source=arch build_env=local tests=on"
PACKAGES["qemu-full"]="source=arch build_env=local tests=on alias=qemu"
PACKAGES["firefox-pure"]="source=ventureoo build_env=local tests=on"
PACKAGES["vim"]="source=arch build_env=local tests=off"

# Optional fallback list for default --nocheck behavior.
# Useful if you prefer list-style control instead of tests=off in PACKAGES.
NO_CHECK_PACKAGES=()

# Optional package-specific custom build commands.
declare -A CUSTOM_LOCAL_BUILD_COMMANDS
declare -A CUSTOM_CHROOT_BUILD_COMMANDS

# Example:
# CUSTOM_LOCAL_BUILD_COMMANDS["firefox"]="ENABLE_BOLT=true makepkg --syncdeps --noconfirm --needed -f"
# CUSTOM_CHROOT_BUILD_COMMANDS["qemu-full"]="sed -i '1i export ENABLE_BOLT=true' PKGBUILD && makechrootpkg -c -r \"\$MASTER_CHROOT\" -d \"\$PWD\""

# Optional package-specific pre/post commands.
declare -A PRE_UPDATE_COMMANDS
declare -A POST_UPDATE_COMMANDS

# Example:
# PRE_UPDATE_COMMANDS["pkgname"]="echo pre"
# POST_UPDATE_COMMANDS["pkgname"]="echo post"

# Packages to compile manually during -U flow.
MANUAL_UPDATE_PACKAGES=("systemd" "qemu-full")

# Sub-packages to hide from install prompt.
SKIP_INSTALL_PACKAGES=("systemd-tests" "qemu-user-static-binfmt" "qemu-user-static" "qemu-guest-agent")
